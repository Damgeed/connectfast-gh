# KEM Data Plug — Backend
# Copy to .env and fill in your values

# Paystack
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx

# Database (defaults to SQLite)
DATABASE_URL=sqlite:///./kemdp.db

# Telecom API (BBS or similar vendor)
TELECOM_API_KEY=
TELECOM_API_URL=

# App
APP_URL=https://damgeed.github.io/connectfast-gh/
CORS_ORIGINS=https://damgeed.github.io
